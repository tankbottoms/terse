{
  "name": "terse",
  "version": "0.1.0",
  "description": "Token-efficient communication for Claude",
  "type": "module",
  "main": "src/cli.ts",
  "bin": {
    "terse": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile terse",
    "build:macos": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile terse-macos",
    "build:linux": "bun build src/cli.ts --compile --target=bun-linux-arm64 --outfile terse-linux",
    "bench": "bun run src/cli.ts bench",
    "lint:text": "bun run src/cli.ts lint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
